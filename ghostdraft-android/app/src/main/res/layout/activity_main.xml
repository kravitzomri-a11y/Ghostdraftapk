<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0D1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#E6EDF3"
            android:textSize="28sp"
            android:textStyle="bold"
            android:paddingTop="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A floating mic that types your speech into any app."
            android:textColor="#8B949E"
            android:textSize="15sp"
            android:paddingTop="6dp"
            android:paddingBottom="28dp" />

        <Button
            android:id="@+id/btnMic"
            style="@style/Step"
            android:text="1. Microphone" />

        <Button
            android:id="@+id/btnOverlay"
            style="@style/Step"
            android:text="2. Draw over apps" />

        <Button
            android:id="@+id/btnAccessibility"
            style="@style/Step"
            android:text="3. Accessibility" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#58A6FF"
            android:textSize="14sp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp" />

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start the floating mic"
            android:textColor="#0D1117"
            android:textStyle="bold"
            android:backgroundTint="#2EA043" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Stop the floating mic"
            android:textColor="#E6EDF3"
            android:backgroundTint="#30363D" />

    </LinearLayout>
</ScrollView>
